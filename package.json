{
  "name": "oj-print-desktop",
  "version": "0.1.4",
  "description": "Olive Jewellery price tag printer — desktop app",
  "main": "src/main/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "publish:win": "electron-builder --win --x64 --publish always",
    "build:mac": "electron-builder --mac",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "in.olivejewellery.printtags",
    "productName": "OJ Label Printer",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Mukeshjavvaji",
        "repo": "oj-price-tag-desktop",
        "releaseType": "release"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logo/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/logo/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
